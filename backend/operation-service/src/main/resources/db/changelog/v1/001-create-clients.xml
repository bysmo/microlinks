<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="op-001" author="microlinks">
        <createTable tableName="clients">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="numero_compte" type="VARCHAR(50)"><constraints nullable="false"/></column>
            <column name="nom_complet" type="VARCHAR(200)"><constraints nullable="false"/></column>
            <column name="prenom" type="VARCHAR(100)"/>
            <column name="nom" type="VARCHAR(100)"/>
            <column name="institution_id" type="UUID"><constraints nullable="false"/></column>
            <column name="nom_institution" type="VARCHAR(200)"/>
            <column name="type_compte" type="VARCHAR(30)"/>
            <column name="telephone" type="VARCHAR(30)"/>
            <column name="email" type="VARCHAR(200)"/>
            <column name="statut" type="VARCHAR(20)" defaultValue="ACTIF"><constraints nullable="false"/></column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="NOW()"><constraints nullable="false"/></column>
        </createTable>
        <createIndex tableName="clients" indexName="idx_client_numero_compte">
            <column name="numero_compte"/>
        </createIndex>
        <createIndex tableName="clients" indexName="idx_client_institution">
            <column name="institution_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
