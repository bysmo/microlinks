<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="op-003" author="microlinks">
        <createTable tableName="historique_statuts">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()"><constraints primaryKey="true" nullable="false"/></column>
            <column name="operation_id" type="UUID"><constraints nullable="false" foreignKeyName="fk_hist_operation" references="operations(id)"/></column>
            <column name="statut_avant" type="VARCHAR(40)"/>
            <column name="statut_apres" type="VARCHAR(40)"><constraints nullable="false"/></column>
            <column name="commentaire" type="TEXT"/>
            <column name="acteur_id" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="acteur_nom" type="VARCHAR(200)"/>
            <column name="institution_id" type="UUID"/>
            <column name="institution_nom" type="VARCHAR(200)"/>
            <column name="date_action" type="TIMESTAMP"><constraints nullable="false"/></column>
        </createTable>
        <createIndex tableName="historique_statuts" indexName="idx_hist_operation">
            <column name="operation_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
