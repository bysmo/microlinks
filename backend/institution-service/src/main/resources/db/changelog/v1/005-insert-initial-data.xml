            <column name="statut">ACTIF</column>
        </insert>
        <insert tableName="zones_monetaires">
            <column name="id" valueComputed="gen_random_uuid()"/>
            <column name="code">BCC</column>
            <column name="libelle">Banque Centrale du Congo</column>
            <column name="devise">CDF</column>
            <column name="description">Zone RDC - Franc Congolais</column>
            <column name="statut">ACTIF</column>
        </insert>
    </changeSet>
</databaseChangeLog>
