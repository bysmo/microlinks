<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="004" author="microlinks">
        <createTable tableName="comptes_correspondance">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="numero_compte" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="libelle" type="VARCHAR(200)"/>
            <column name="institution_proprietaire_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_cc_institution_prop" references="institutions(id)"/>
            </column>
            <column name="banque_domiciliataire_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_cc_banque_dom" references="institutions(id)"/>
            </column>
            <column name="type_compte" type="VARCHAR(30)"/>
            <column name="statut" type="VARCHAR(20)" defaultValue="ACTIF">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="comptes_correspondance"
                             columnNames="numero_compte, banque_domiciliataire_id"
                             constraintName="uk_compte_correspondance"/>
    </changeSet>
</databaseChangeLog>
