<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003" author="microlinks">
        <createTable tableName="agences">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="nom" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="institution_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_agence_institution" references="institutions(id)"/>
            </column>
            <column name="adresse" type="TEXT"/>
            <column name="telephone" type="VARCHAR(30)"/>
            <column name="email" type="VARCHAR(200)"/>
            <column name="statut" type="VARCHAR(20)" defaultValue="ACTIF">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="agences" columnNames="code, institution_id" constraintName="uk_agence_code_institution"/>
    </changeSet>
</databaseChangeLog>
