<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="002" author="microlinks">
        <createTable tableName="institutions">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(20)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="nom" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="sigle" type="VARCHAR(50)"/>
            <column name="type_institution" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="zone_monetaire_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_inst_zone" references="zones_monetaires(id)"/>
            </column>
            <column name="pays" type="VARCHAR(3)">
                <constraints nullable="false"/>
            </column>
            <column name="adresse" type="TEXT"/>
            <column name="telephone" type="VARCHAR(30)"/>
            <column name="email" type="VARCHAR(200)"/>
            <column name="site_web" type="VARCHAR(200)"/>
            <column name="logo_url" type="VARCHAR(500)"/>
            <column name="banque_correspondante_id" type="UUID"/>
            <column name="statut" type="VARCHAR(20)" defaultValue="ACTIF">
                <constraints nullable="false"/>
            </column>
            <column name="date_adhesion" type="DATE"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="updated_by" type="VARCHAR(100)"/>
        </createTable>

        <createIndex tableName="institutions" indexName="idx_institutions_code">
            <column name="code"/>
        </createIndex>
        <createIndex tableName="institutions" indexName="idx_institutions_type">
            <column name="type_institution"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
