{
  "id": "microlinks",
  "realm": "microlinks",
  "displayName": "MicroLinks",
  "displayNameHtml": "<span style='font-weight:bold'>Micro</span>Links",
  "loginTheme": "microlinks",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 3600,
  "refreshTokenMaxReuse": 0,
  "clients": [
    {
      "clientId": "microlinks-frontend",
      "name": "MicroLinks Frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "rootUrl": "http://localhost:3000",
      "baseUrl": "/",
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:3001",
        "http://localhost:8080"
      ],
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "institution_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "institution_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "institution_id",
            "jsonType.label": "String",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "institution_nom",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "institution_nom",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "institution_nom",
            "jsonType.label": "String",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "MICROLINKS-UI",
      "name": "MicroLinks UI Client",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "rootUrl": "http://localhost:3000",
      "baseUrl": "/",
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:3001",
        "http://localhost:8080"
      ],
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "institution_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "institution_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "institution_id",
            "jsonType.label": "String",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "institution_nom",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "institution_nom",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "institution_nom",
            "jsonType.label": "String",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "microlinks-backend",
      "name": "MicroLinks Backend",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "ADMIN_PLATEFORME",
        "description": "Administrateur global de la plateforme MicroLinks"
      },
      {
        "name": "ADMIN_INSTITUTION",
        "description": "Administrateur d'une institution (banque ou micro/méso-finance)"
      },
      {
        "name": "AGENT_SAISIE",
        "description": "Agent habilité à saisir des opérations"
      },
      {
        "name": "AGENT_VALIDATION",
        "description": "Agent habilité à valider des opérations"
      },
      {
        "name": "LECTEUR",
        "description": "Accès en lecture seule aux opérations et rapports"
      },
      {
        "name": "ADMIN",
        "description": "SaaS Platform Administrator",
        "composite": true,
        "composites": {
          "realm": ["ADMIN_PLATEFORME"]
        }
      },
      {
        "name": "MESO_ADMIN",
