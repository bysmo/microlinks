# ===================================================
# MicroLinks - Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs
# ===================================================

# Base de données PostgreSQL
POSTGRES_USER=microlinks
POSTGRES_PASSWORD=MicroLinks@2024#Secure
POSTGRES_HOST=postgres

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=KeycloakAdmin@2024#
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=microlinks
KEYCLOAK_CLIENT_ID=microlinks-backend
KEYCLOAK_CLIENT_SECRET=microlinks-secret-key-change-me

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=Redis@2024#Secure

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=microlinks
RABBITMQ_PASSWORD=RabbitMQ@2024#

# Mail SMTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=microlinks@yourdomain.com
MAIL_PASSWORD=your-mail-password

# JWT
JWT_ISSUER_URI=http://keycloak:8080/realms/microlinks

# Services ports (internes)
API_GATEWAY_PORT=8080
INSTITUTION_SERVICE_PORT=8082
OPERATION_SERVICE_PORT=8083
RAPPORT_SERVICE_PORT=8084
NOTIFICATION_SERVICE_PORT=8085

# Frontend
VITE_API_BASE_URL=http://localhost:8080
VITE_KEYCLOAK_URL=http://localhost:8443
VITE_KEYCLOAK_REALM=microlinks
VITE_KEYCLOAK_CLIENT_ID=microlinks-frontend

# Application
APP_NAME=MicroLinks
APP_VERSION=1.0.0
APP_ENV=production

# =====================================================================
# SFTP Service — Échanges de fichiers inter-institutions
# =====================================================================

# Port du sftp-service
SFTP_SERVICE_PORT=8087

# Expression cron de la collecte SFTP (format Spring : seconde minute heure jour mois jourSemaine)
# Exemples :
#   Toutes les 5 min : 0 */5 * * * *
#   Toutes les heures : 0 0 * * * *
#   1x/jour à 8h00  : 0 0 8 * * *
SFTP_POLLING_CRON=0 */5 * * * *

# Clé de chiffrement AES-256 pour les credentials SFTP stockés en base
# OBLIGATOIRE en production : générer une clé de 32 caractères aléatoires
# DOIT être identique sur institution-service ET sftp-service
SFTP_ENCRYPTION_KEY=MicroLinksSftp#Key256bits!Secure
